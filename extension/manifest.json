{
  "manifest_version": 3,
  "name": "Web Copilot",
  "version": "1.0",
  "description": "AI-powered web page summarizer and insights generator.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "clipboardWrite"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "popup.html",
        "style.css",
        "popup.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}